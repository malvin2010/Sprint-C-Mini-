{
  "version": 2,
  "name": "malvin-c-sprint",
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/telegram", "dest": "index.js" },
    { "src": "/api/pair/(.*)", "dest": "index.js" },
    { "src": "/api/status", "dest": "index.js" },
    { "src": "/(.*)", "dest": "index.js" }
  ],
  "env": {
    "TELEGRAM_BOT_TOKEN": "@telegram_bot_token",
    "ADMIN_IDS": "@admin_ids"
  }
}
